# Docker Compose Project Name
COMPOSE_PROJECT_NAME=hybrid-rag

# Custom API (OpenAI-compatible)
API_URL=http://localhost:5000/v1/
API_KEY=your_api_key_here

# OpenAI API key (Optional)
OPENAI_API_KEY=your_openai_key_here

# ===== Models Configuration =====
LLM_MODEL=Qwen/Qwen3.5-4B
EMBEDDER_MODEL=contextboxai/halong_embedding
SPARSE_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions

# ===== Generation Configuration =====
GENERATION_MAX_TOKENS=4096
GENERATION_TEMPERATURE=0.6
GENERATION_TOP_P=0.95
GENERATION_PRESENCE_PENALTY=0
GENERATION_FREQUENCY_PENALTY=0

# ===== Extraction Configuration =====
EXTRACTION_MAX_TOKENS=2048
EXTRACTION_TEMPERATURE=0.1
EXTRACTION_TOP_P=0.1
EXTRACTION_PRESENCE_PENALTY=0.0
EXTRACTION_FREQUENCY_PENALTY=0.0

# ===== Neo4j Configuration =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ===== Qdrant Configuration =====
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=hybridrag_chunks